<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Caller photo fills most of the screen — photo-first design -->
    <ImageView
        android:id="@+id/callerPhoto"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/callerName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="@string/caller_photo_description" />

    <TextView
        android:id="@+id/callerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="48dp"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/controlsBarrier"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Large, unmistakable answer / decline buttons -->
    <ImageView
        android:id="@+id/declineButton"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:layout_marginBottom="64dp"
        android:layout_marginStart="64dp"
        android:src="@drawable/ic_call_decline"
        android:background="@drawable/bg_decline_circle"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:contentDescription="@string/decline_call_description" />

    <ImageView
        android:id="@+id/answerButton"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:layout_marginBottom="64dp"
        android:layout_marginEnd="64dp"
        android:src="@drawable/ic_call_answer"
        android:background="@drawable/bg_answer_circle"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="@string/answer_call_description" />

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/controlsBarrier"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="top"
        app:constraint_referenced_ids="answerButton,declineButton" />

</androidx.constraintlayout.widget.ConstraintLayout>

<!--
  NOTE: you'll need to add these drawables yourself:
  - ic_call_answer.xml / ic_call_decline.xml (vector icons, e.g. from
    Material Symbols "call" and "call_end")
  - bg_answer_circle.xml / bg_decline_circle.xml (green/red circle shapes)
  - default_avatar.png (fallback silhouette for contacts without a photo)
  And add these strings to res/values/strings.xml:
  <string name="caller_photo_description">Caller photo</string>
  <string name="answer_call_description">Answer call</string>
  <string name="decline_call_description">Decline call</string>
-->
